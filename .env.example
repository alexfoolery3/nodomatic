# ==========================================================================
# Nodomatic — variabili d'ambiente
# --------------------------------------------------------------------------
# Copia questo file in `.env.local` e riempi i valori:  cp .env.example .env.local
# NON committare i segreti (.env.local è gitignored). Guida passo-passo numerata:
# docs/SETUP-LOCAL.md
#
# DUE LIVELLI di setup (riempi solo quello che ti serve):
#   • LIVELLO 1 — solo login + dashboard. Minimo per far girare l'app in
#     locale e verificare auth/UI (~10 min). Bastano le variabili di LIVELLO 1.
#   • LIVELLO 2 — funnel completo + reporting. Aggiungi le chiavi esterne man
#     mano che vuoi attivare scraping, audit, AI, email, screenshot, report.
#
# Tutte le variabili senza prefisso NEXT_PUBLIC_ sono SOLO server-side.
# ==========================================================================


# ##########################################################################
# LIVELLO 1 — Login + Dashboard  (minimo indispensabile)
# ##########################################################################

# ---- App ----
# URL pubblico dell'app. In locale lascia localhost; in produzione: https://nodomatic.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (Neon Postgres serverless) ----  [B1]
# Crea un progetto su https://neon.tech e incolla qui la connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---- Auth (BetterAuth) ----  [B2]
# Genera il secret con:  openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---- Privacy ----  [B2]
# Salt per hashare gli IP dei visitatori delle landing (GDPR, PRD §12).
# Genera con:  openssl rand -base64 32   (serve solo alle landing /p/[slug],
# ma impostalo comunque: evita un fallback debole.)
IP_HASH_SALT=

# ---- Seed primo admin ----  [B3]
# Usati una tantum da `pnpm db:seed` per creare il primo utente admin.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin


# ##########################################################################
# LIVELLO 2 — Funnel completo + Reporting  (chiavi esterne, opzionali finché
# non attivi la feature relativa)
# ##########################################################################

# ---- Inngest (background jobs) ----
# In locale puoi usare la CLI dev senza chiavi:  npx inngest-cli@latest dev
# Queste servono solo in produzione (sync su /api/inngest).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Apify (Google Maps Scraper) ----  [B4]
APIFY_TOKEN=

# ---- Apollo.io (arricchimento email, opzionale) ----
APOLLO_API_KEY=

# ---- PageSpeed Insights API (audit performance) ----  [B4]
PAGESPEED_API_KEY=

# ---- Screenshot (Browserless o Cloudflare Browser Rendering) ----  [B4]
BROWSERLESS_TOKEN=

# ---- Claude API (generazione contenuti AI) ----  [B4]
ANTHROPIC_API_KEY=

# ---- Resend (email outreach) ----  [B4]
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
OUTREACH_FROM_EMAIL=
# Reply-To: dove arrivano le risposte all'outreach (una casella che controlli, es. la tua email). Opzionale.
OUTREACH_REPLY_TO=
# Email interna per gli alert di monitoraggio (opzionale)
TEAM_NOTIFY_EMAIL=

# ---- Cloudflare R2 (storage screenshot) ----  [B4]
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ---- Reporting / client analytics (agency-managed) ----
# JSON della service account Google (GA4/Google Ads) codificato in base64.
# base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
# Meta Marketing API + insights organici: token System User del Business Manager
META_SYSTEM_USER_TOKEN=
# Google Ads (MCC): developer token + OAuth refresh token del manager account
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
