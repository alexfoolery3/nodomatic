# ==========================================================================
# Nodomatic Prospector — variabili d'ambiente
# Copia questo file in `.env.local` e riempi i valori. NON committare i segreti.
# Tutte le variabili senza prefisso NEXT_PUBLIC_ sono SOLO server-side.
# ==========================================================================

# ---- App ----
# URL pubblico dell'app. In produzione: https://nodomatic.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (Neon Postgres serverless) ----
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---- Auth (BetterAuth) ----
# Genera con: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---- Seed primo admin (solo per `pnpm db:seed`, una tantum) ----
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# ---- Inngest (background jobs) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Apify (Google Maps Scraper) ----
APIFY_TOKEN=

# ---- Apollo.io (arricchimento email, opzionale) ----
APOLLO_API_KEY=

# ---- PageSpeed Insights API (audit performance) ----
PAGESPEED_API_KEY=

# ---- Screenshot (Browserless o Cloudflare Browser Rendering) ----
BROWSERLESS_TOKEN=

# ---- Claude API (generazione contenuti AI) ----
ANTHROPIC_API_KEY=

# ---- Resend (email outreach) ----
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
OUTREACH_FROM_EMAIL=
# Email interna per gli alert di monitoraggio (opzionale)
TEAM_NOTIFY_EMAIL=

# ---- Cloudflare R2 (storage screenshot) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ---- Privacy ----
# Salt usato per hashare gli IP dei visitatori delle landing (GDPR, PRD §12)
IP_HASH_SALT=

# ---- Reporting / client analytics (agency-managed) ----
# JSON della service account Google (GA4/Google Ads) codificato in base64.
# base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
# Meta Marketing API: token System User del Business Manager (permesso ads_read)
META_SYSTEM_USER_TOKEN=
# Aggiunti nelle fasi successive: GOOGLE_ADS_DEVELOPER_TOKEN, ...
